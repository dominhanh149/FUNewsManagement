@{
    ViewData["Title"] = "Audit Log";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h2 class="fw-bold mb-0" style="color:#1a1a2e">
            <i class="bi bi-clock-history me-2" style="color:#6c63ff"></i>Audit Log
        </h2>
        <p class="text-muted mb-0 mt-1">Lịch sử tất cả thao tác CRUD — ai đã làm gì và khi nào</p>
    </div>
</div>

<!-- Filter Card -->
<div class="card border-0 shadow-sm mb-4" style="border-radius:16px">
    <div class="card-body p-4">
        <h6 class="fw-semibold mb-3 text-muted text-uppercase" style="font-size:.75rem;letter-spacing:.08em">
            <i class="bi bi-funnel me-1"></i>Bộ lọc
        </h6>
        <div class="row g-3 align-items-end">
            <div class="col-md-2">
                <label class="form-label fw-medium small">Entity Type</label>
                <select id="filterEntityType" class="form-select" style="border-radius:10px">
                    <option value="">— Tất cả —</option>
                    <option value="NewsArticle">NewsArticle</option>
                    <option value="Category">Category</option>
                    <option value="Tag">Tag</option>
                    <option value="SystemAccount">SystemAccount</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label fw-medium small">Action</label>
                <select id="filterAction" class="form-select" style="border-radius:10px">
                    <option value="">— Tất cả —</option>
                    <option value="Create">Create</option>
                    <option value="Update">Update</option>
                    <option value="Delete">Delete</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label fw-medium small">Người thực hiện</label>
                <select id="filterEditor" class="form-select" style="border-radius:10px">
                    <option value="">— Tất cả —</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label fw-medium small">Từ ngày</label>
                <input id="filterFrom" type="date" class="form-control" style="border-radius:10px" />
            </div>
            <div class="col-md-2">
                <label class="form-label fw-medium small">Đến ngày</label>
                <input id="filterTo" type="date" class="form-control" style="border-radius:10px" />
            </div>
            <div class="col-md-2 d-flex gap-2 align-items-end">
                <button id="btnSearch" class="btn flex-fill text-white fw-semibold"
                        style="background:linear-gradient(135deg,#6c63ff,#4facfe);border-radius:8px;border:none">
                    <i class="bi bi-search"></i> Lọc
                </button>
                <button id="btnReset" class="btn btn-outline-secondary" style="border-radius:8px">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Loading -->
<div id="loading" class="text-center py-5 d-none">
    <div class="spinner-border" style="color:#6c63ff;width:2.5rem;height:2.5rem" role="status"></div>
    <p class="mt-2 text-muted">Đang tải...</p>
</div>

<!-- Table -->
<div id="auditTable" class="card border-0 shadow-sm d-none" style="border-radius:16px">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0" style="font-size:.87rem">
                <thead style="background:#f6f5ff">
                    <tr>
                        <th class="px-3 py-3 border-0 text-muted fw-semibold" style="font-size:.75rem;text-transform:uppercase;width:60px">#</th>
                        <th class="py-3 border-0 text-muted fw-semibold" style="font-size:.75rem;text-transform:uppercase;width:100px">Action</th>
                        <th class="py-3 border-0 text-muted fw-semibold" style="font-size:.75rem;text-transform:uppercase;width:130px">Entity Type</th>
                        <th class="py-3 border-0 text-muted fw-semibold" style="font-size:.75rem;text-transform:uppercase;width:160px">Entity ID</th>
                        <th class="py-3 border-0 text-muted fw-semibold" style="font-size:.75rem;text-transform:uppercase;width:160px">Người thực hiện</th>
                        <th class="py-3 border-0 text-muted fw-semibold" style="font-size:.75rem;text-transform:uppercase;width:160px">Thời gian</th>
                        <th class="py-3 border-0 text-muted fw-semibold text-center" style="font-size:.75rem;text-transform:uppercase;width:80px">Before</th>
                        <th class="py-3 pe-4 border-0 text-muted fw-semibold text-center" style="font-size:.75rem;text-transform:uppercase;width:80px">After</th>
                    </tr>
                </thead>
                <tbody id="auditBody"></tbody>
            </table>
        </div>
    </div>
</div>

<!-- Paging -->
<div class="d-flex align-items-center justify-content-between mt-3">
    <span id="pagingInfo" class="text-muted small"></span>
    <div class="d-flex gap-2">
        <button id="btnPrev" class="btn btn-sm btn-outline-secondary" style="border-radius:8px" disabled>
            <i class="bi bi-chevron-left"></i> Trước
        </button>
        <button id="btnNext" class="btn btn-sm btn-outline-secondary" style="border-radius:8px" disabled>
            Sau <i class="bi bi-chevron-right"></i>
        </button>
    </div>
</div>

<!-- JSON Modal -->
<div class="modal fade" id="jsonModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">JSON Data</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <pre id="jsonModalBody" class="bg-light p-3 rounded" style="font-size:.85rem;max-height:400px;overflow:auto"></pre>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <script src="~/js/admin.auditlog.js?v=2"></script>
}
